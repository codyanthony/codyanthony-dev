{
  "name": "codyanthony-dev",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "lint:js": "eslint .",
    "lint:md": "markdownlint-cli2",
    "lint": "pnpm run lint:js && pnpm run lint:md",
    "build": "pnpm run lint && pnpm astro check && astro build",
    "preview": "pnpm run build && wrangler dev --config dist/server/wrangler.json",
    "deploy": "pnpm run build && wrangler deploy --config dist/server/wrangler.json",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.6.0",
    "@astrojs/mdx": "^6.0.1",
    "astro": "^6.4.2",
    "sharp": "^0.34.2",
    "workers-og": "^0.0.27"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.39.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^9.39.2",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-mdx": "^3.8.1",
    "markdownlint-cli2": "^0.22.1",
    "puppeteer": "^25.1.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.95.0"
  }
}
