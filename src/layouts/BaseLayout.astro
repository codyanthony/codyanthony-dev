---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Documentation strategist for complex software products. Content strategy, documentation systems, AI workflows.",
  ogImage,
  noindex = false,
} = Astro.props;

const siteName = "Cody Anthony";
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

// og:image defaults to a dynamically generated, per-page social card
// (src/pages/og/[slug].png.ts — rendered then cached to R2 on first scrape).
// The slug is the page's path, so each URL gets its own cacheable card titled
// with the page title. Pages can override with an explicit `ogImage` (a
// hand-made card or a static asset like /og.png).
const ogSlug =
  Astro.url.pathname.replace(/^\/+|\/+$/g, "").replace(/\//g, "-") || "home";
const resolvedOgImage = ogImage
  ? new URL(ogImage, Astro.site).toString()
  : new URL(
      `/og/${ogSlug}.png?title=${encodeURIComponent(title)}`,
      Astro.site,
    ).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    {noindex && <meta name="robots" content="noindex" />}

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <slot name="head" />
  </head>
  <body>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
