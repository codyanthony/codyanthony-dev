---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

function hrefFor(entry: (typeof posts)[number]) {
  return `/blog/${entry.id.replace(/\.(md|mdx)$/, "")}/`;
}

function shortDate(d: Date) {
  return d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<BaseLayout
  title="Blog"
  description="Essays on documentation strategy, content infrastructure, and AI workflows for technical writers."
>
  <section class="section">
    <div class="prose-wide">
      <p class="section__eyebrow">Blog</p>
      <h1>Writing on documentation strategy, content systems, and AI workflows.</h1>
      <p class="section__lede">
        Essays on how complex software products are documented and understood.
        Content infrastructure, docs-as-code patterns, AI-assisted writing, and
        the craft of moving information from rough inputs to trusted output.
      </p>
    </div>
  </section>

  <section class="cs-section">
    <div class="prose-wide">
      <ul class="cs-list">
        {
          posts.map((entry) => (
            <li class="cs-list__item">
              <a class="cs-list__link" href={hrefFor(entry)}>
                <span class="cs-list__title">{entry.data.title}</span>
                <span class="cs-list__description">
                  {entry.data.description}
                </span>
                <span class="cs-list__meta">
                  <time datetime={entry.data.date.toISOString()}>
                    {shortDate(entry.data.date)}
                  </time>
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
