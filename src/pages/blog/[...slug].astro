---
import { getCollection, render } from "astro:content";
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("blog", ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.(md|mdx)$/, "") },
    props: { entry },
  }));
}

type Props = { entry: Awaited<ReturnType<typeof getCollection<"blog">>>[number] };

const { entry } = Astro.props as Props;
const { Content } = await render(entry);

const slug = entry.id.replace(/\.(md|mdx)$/, "");

const wordCount = entry.body?.trim().split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.round(wordCount / 200));

const ogImage = `/og/blog/${slug}.png`;
---

<BlogPostLayout
  title={entry.data.title}
  description={entry.data.description}
  date={entry.data.date}
  readingTime={readingTime}
  ogImage={ogImage}
  slug={slug}
>
  <Content />
</BlogPostLayout>
